#!/usr/bin/env bash

cd ~/sinom/sinom-api/db
docker compose up -d
cd ~/sinom/sinom-web/
tmux new -s server -d 'yarn start:sinom'
tmux new -s frontend -d 'nvim .'

cd ~/sinom/sinom-api/
yarn db:seed # <-- bygger dummydata
yarn migrate # <-- migrerar databas
tmux split-window -t server -h 'yarn dev'
tmux split-window -t server -v 'yarn studio'
tmux new -s backend -d 'nvim .'
tmux at
