#!/usr/bin/env bash

cd ~/dev/CoRent/backend/
docker compose up -d
cd ~/dev/CoRent/frontend-svelteKit/
tmux new -s server -d 'npm run dev'
tmux new -s 'git frontend' -d 'lazygit'
tmux new -s frontend -d 'nvim .'

cd ~/dev/CoRent/backend/
tmux split-window -t server -h 'npm run dev'
tmux new -s 'git backend' -d 'lazygit'
tmux new -s backend -d 'nvim .'
tmux at
