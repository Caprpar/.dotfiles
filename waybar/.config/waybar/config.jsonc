// -*- mode: jsonc -*-
{
  // "layer": "top", // Waybar at top layer
  // "position": "bottom", // Waybar position (top|bottom|left|right)
  // "height": 30, // Waybar height (to be removed for auto height)
  // "width": 1280, // Waybar width
  "spacing": 0, // Gaps between modules (4px)
  // Choose the order of the modules
  "modules-left": [
    "custom/archicon",
    "hyprland/workspaces",
    "hyprland/mode",
    "hyprland/scratchpad",
    "custom/media",
  ],
  "modules-center": [],
  "modules-right": [
    // "hyprland/language",
    "pulseaudio",
    "memory",
    "cpu",
    "network",
    "battery",
    "clock"
    // "tray"
    // "keyboard-state",
    // "power-profiles-daemon",
    // "battery#bat0",
  ],
  //   "disable-scroll": true,
  //   "all-outputs": true,
  //   "warp-on-scroll": false,
  //   "format": "{name}: {icon}",
  //   "format-icons": {
  //     "1": "ΎΕι",
  //     "2": "ΎΚρ",
  //     "3": "ΎΕκ",
  //     "4": "ΎΗ╝",
  //     "5": "ΎΒ╡",
  //     "urgent": "ΎΒς",
  //     "focused": "ΎΗΤ",
  //     "default": "ΎΕΣ",
  //   },
